---

<section class="reveal flex flex-col w-full relative overflow-hidden">
  <!-- Adorno Floral Superior (Derecha) -->
  <img
    src="/assets/tema2/marco.png"
    class="absolute right-[-40%] sm:right-[-20%] top-0 h-[60vh] object-contain z-0 pointer-events-none drop-shadow-sm"
    alt="Decoración floral"
  />

  <!-- Adorno Floral Inferior (Izquierda) -->
  <img
    src="/assets/tema2/marco.png"
    class="absolute left-[-40%] sm:left-[-20%] bottom-0 h-[60vh] object-contain z-0 pointer-events-none drop-shadow-sm scale-x-[-1] rotate-180"
    alt="Decoración floral"
  />
  <div class="flex flex-col w-full gap-12 relative mt-40 my-10">
    {
      eventos.map((evento, index) => (
        <div class="relative flex flex-col items-center text-center">
          <img src={evento.icon} class="h-10 mb-4 z-10" />

          <h2 class="text-3xl sm:text-4xl font-yrsa tracking-[0.25em] text-dark-blue uppercase mb-2">
            {evento.name}
          </h2>
          <p class="text-sm sm:text-base font-abeezee text-gray-600 mb-4 tracking-wide">
            {evento.lugar}
          </p>

          <button
            class="map-toggle-btn bg-dark-blue text-white font-abeezee text-xs tracking-widest uppercase py-2 px-6 rounded-full hover:scale-105 transition-transform shadow-md"
            data-index={index}
          >
            {evento.Ubicacion}
          </button>

          <div
            id={`map-container-${index}`}
            class="map-container overflow-hidden max-h-0 opacity-0 transition-all duration-500 ease-in-out w-full max-w-md mx-auto mt-6 px-4"
          >
            <div class="aspect-video w-full rounded-xl overflow-hidden shadow-lg border-2 border-dark-blue/10">
              <iframe
                src={evento.mapUrl}
                width="100%"
                height="100%"
                style="border:0;"
                allowfullscreen=""
                loading="lazy"
                referrerpolicy="no-referrer-when-downgrade"
              />
            </div>
          </div>
        </div>
      ))
    }
  </div>

  <h2
    class="text-3xl sm:text-4xl font-yrsa tracking-[0.25em] text-dark-blue uppercase mb-20 w-3/4 mx-auto text-center my-10"
  >
    Itinerario de actividades
  </h2>

  <div class="relative w-full items-center mx-auto pb-10">
    <div class="relative w-full max-w-[300px] mx-auto px-8 rounded-lg">
    <div class="absolute left-[50px] top-12 bottom-12 w-px bg-dark-blue/30"></div>

    <div class="space-y-12">
      {actividades.map((act) => (
        <div class="relative flex items-center gap-8">
          <!-- Icon -->
          <div class="relative z-10 w-15 h-15 flex items-center justify-center bg-white/20 backdrop-blur-sm rounded-full border border-dark-blue/10 text-dark-blue">
            <Fragment set:html={act.icon} />
          </div>

          <!-- Text -->
          <div class="flex flex-col">
            <span class="font-abeezee text-sm tracking-widest text-dark-blue/80 font-bold">{act.time}</span>
            <span class="font-abeezee text-sm text-dark-blue/90">{act.name}</span>
          </div>
        </div>
      ))}
    </div>
    </div>
  </div>
</section>

<script>
  const buttons = document.querySelectorAll(".map-toggle-btn");
  buttons.forEach((btn) => {
    btn.addEventListener("click", () => {
      const index = btn.getAttribute("data-index");
      const container = document.getElementById(`map-container-${index}`);
      if (container) {
        const isOpen = !container.classList.contains("max-h-0");

        if (isOpen) {
          container.classList.add("max-h-0", "opacity-0");
          container.classList.remove("max-h-[500px]", "opacity-100");
          btn.textContent = "Ver mapa";
        } else {
          container.classList.remove("max-h-0", "opacity-0");
          container.classList.add("max-h-[500px]", "opacity-100");
          btn.textContent = "Cerrar mapa";
        }
      }
    });
  });
</script>
