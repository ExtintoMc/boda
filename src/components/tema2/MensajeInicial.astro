---
import MusicaFondo from "../shared/MusicaFondo.astro";
import Reproductor from "../shared/MusicaFondo.astro";
---

<section class=" w-full flex flex-col overflow-hidden pb-16">
  <!-- Right edge floral decoration -->
  <img
    src="/assets/tema2/marco.png"
    class="absolute right-[-50%] sm:right-[-25%] top-1/4 h-[80vh] object-contain opacity-90 z-0 pointer-events-none drop-shadow-lg"
    alt="Hojas acuarela"
  />

  <div
    class="z-10 flex flex-col items-center w-full px-6 pt-20 sm:pt-28 text-center text-dark-blue"
  >
    <h2
      class="text-3xl sm:text-4xl font-yrsa tracking-[0.25em] text-dark-blue uppercase mb-10"
    >
      Estamos felices
    </h2>

    <p
      class="text-xs sm:text-sm font-abeezee leading-loose mb-8 max-w-[280px] sm:max-w-sm"
    >
      de compartir con ustedes la alegría<br />
      de un día inolvidable para nosotros -<br />
      el día de nuestra boda
    </p>

    <p
      class="text-xs sm:text-sm font-abeezee leading-loose mb-12 max-w-[280px] sm:max-w-sm"
    >
      ¡los invitamos a unirse a nuestra<br />
      celebración y decorar<br />
      con su presencia!
    </p>
  </div>
  <MusicaFondo />
</section>
