---
---

<section class="relative w-full pt-12 pb-4 flex flex-col items-center">
  <!-- Top Decoration -->
  <img 
    src="/src/assets/leaf.png" 
    class="absolute top-0 right-[-10%] w-48 opacity-60 pointer-events-none" 
    alt="leaves"
  />

  <div class="z-10 text-center px-8 mb-12">
    <p class="font-abeezee text-[10px] tracking-[0.2em] text-dark-blue/60 uppercase leading-relaxed max-w-[200px] mx-auto">
      POR ENCIMA DE TODO, VÍSTANSE DE AMOR, QUE ES EL VÍNCULO PERFECTO. <br/>
      <span class="opacity-50">COL 3:14-15</span>
    </p>
  </div>

  <div class="flex flex-col items-center mb-12">
    <div class="flex items-center gap-4 text-6xl font-yrsa text-dark-blue">
      <span>M</span>
      <div class="w-px h-12 bg-dark-blue/20"></div>
      <span>A</span>
    </div>
    <span class="font-abeezee text-[10px] tracking-[0.3em] text-dark-blue/50 uppercase mt-4">Nuestra Boda</span>
  </div>

  <div class="relative w-full h-[400px] overflow-hidden shadow-inner">
    <!-- Torn paper effect simulation -->
    <div class="absolute top-0 left-0 w-full h-4 bg-white z-20" style="clip-path: polygon(0 0, 10% 80%, 20% 40%, 30% 90%, 40% 50%, 50% 100%, 60% 40%, 70% 80%, 80% 20%, 90% 70%, 100% 0);"></div>
    
    <img 
      src="/src/assets/fotos.webp" 
      class="w-full h-full object-cover" 
      alt="Manu & Aru"
    />

    <div class="absolute bottom-0 left-0 w-full h-4 bg-white z-20" style="clip-path: polygon(0 100%, 10% 20%, 20% 60%, 30% 10%, 40% 50%, 50% 0%, 60% 60%, 70% 20%, 80% 80%, 90% 30%, 100% 100%);"></div>
  </div>
</section>
