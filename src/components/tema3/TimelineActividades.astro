---
const actividades = [
  {
    name: "Iglesia",
    time: "6:00 PM",
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg>',
  },
  {
    name: "Cóctel de bienvenida",
    time: "7:30 PM",
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg>',
  },
  {
    name: "Entrada de novios",
    time: "8:45 PM",
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg>',
  },
  {
    name: "Banquete",
    time: "9:00 PM",
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6"><circle cx="12" cy="12" r="10"></circle><circle cx="12" cy="12" r="6"></circle></svg>',
  },
  {
    name: "Fiesta",
    time: "10:00 PM",
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7z"></path><circle cx="12" cy="12" r="3"></circle></svg>',
  },
  {
    name: "Despedida",
    time: "3:30 AM",
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>',
  },
];
---

<section class="relative w-full py-16 px-10 flex flex-col items-center bg-white">
  <div class="w-full space-y-16 mb-20">
    <!-- Ceremony -->
    <div class="flex flex-col items-center text-center">
      <span class="font-abeezee text-[11px] tracking-[0.2em] text-dark-blue/80 font-bold mb-1">6:00 PM</span>
      <h3 class="font-yrsa text-xl tracking-[0.2em] text-dark-blue uppercase mb-2">Ceremonia Religiosa</h3>
      <p class="font-abeezee text-[10px] text-dark-blue/60 uppercase mb-1 font-bold">Parroquia San Pedro Apóstol</p>
      <p class="font-abeezee text-[10px] leading-relaxed text-dark-blue/50 mb-6">
        P.º de las Américas 2538, Contry La Silla 1er Sector, Monterrey, N.L.
      </p>
      <a 
        href="https://maps.app.goo.gl/9u7X2RzX8v1P1P1P1" 
        target="_blank" 
        class="bg-dark-blue text-white font-abeezee text-[9px] tracking-[0.3em] uppercase py-3 px-10 rounded-sm hover:bg-dark-blue/90 transition-all shadow-md"
      >
        Ver Ubicación
      </a>
    </div>

    <!-- Reception -->
    <div class="flex flex-col items-center text-center">
      <span class="font-abeezee text-[11px] tracking-[0.2em] text-dark-blue/80 font-bold mb-1">8:00 PM</span>
      <h3 class="font-yrsa text-xl tracking-[0.2em] text-dark-blue uppercase mb-2">Recepción</h3>
      <p class="font-abeezee text-[10px] text-dark-blue/60 uppercase mb-1 font-bold">Salón de Eventos Royal</p>
      <p class="font-abeezee text-[10px] leading-relaxed text-dark-blue/50 mb-6">
        Av. Constitución 1234, Centro, Monterrey, N.L.
      </p>
      <a 
        href="#" 
        class="bg-dark-blue text-white font-abeezee text-[9px] tracking-[0.3em] uppercase py-3 px-10 rounded-sm hover:bg-dark-blue/90 transition-all shadow-md"
      >
        Ver Ubicación
      </a>
    </div>
  </div>

  <h2 class="font-abeezee text-[11px] tracking-[0.3em] text-dark-blue/80 uppercase mb-12">Itinerario de Actividades</h2>

  <div class="relative w-full max-w-[320px] bg-pastel/10 py-12 px-8 rounded-lg overflow-hidden">
    <div class="absolute left-[50px] top-12 bottom-12 w-px bg-dark-blue/30"></div>

    <div class="space-y-12">
      {actividades.map((act) => (
        <div class="relative flex items-center gap-8">
          <div class="relative z-10 w-10 h-10 flex items-center justify-center bg-white rounded-full border border-dark-blue/10 text-dark-blue">
            <Fragment set:html={act.icon} />
          </div>

          <div class="flex flex-col">
            <span class="font-abeezee text-[10px] tracking-widest text-dark-blue/80 font-bold">{act.time}</span>
            <span class="font-parisienne text-lg text-dark-blue/90">{act.name}</span>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
