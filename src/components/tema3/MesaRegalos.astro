---

<section class="relative w-full py-16 px-8 flex flex-col items-center bg-white">
  <!-- Pases -->
  <div class="flex flex-col items-center text-center mb-16">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" class="w-10 h-10 text-dark-blue/60 mb-4">
      <rect x="3" y="4" width="18" height="16" rx="2"></rect>
      <line x1="3" y1="10" x2="21" y2="10"></line>
    </svg>
    <span class="font-abeezee text-[10px] tracking-[0.2em] text-dark-blue/60 uppercase mb-2">Pases</span>
    <p class="font-abeezee text-[11px] text-dark-blue/80 uppercase mb-4">Tenemos reservados</p>
    <div class="flex items-center gap-4">
      <span class="font-abeezee text-[10px] tracking-[0.2em] text-dark-blue/60 uppercase">Para ti</span>
      <div class="w-12 h-12 flex items-center justify-center border border-dark-blue/20 rounded-md">
        <span class="font-yrsa text-2xl text-dark-blue">2</span>
      </div>
      <span class="font-abeezee text-[10px] tracking-[0.2em] text-dark-blue/60 uppercase">Lugares</span>
    </div>
  </div>

  <!-- Sugerencia de regalo -->
  <div class="flex flex-col items-center text-center mb-16 max-w-[300px]">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" class="w-10 h-10 text-dark-blue/60 mb-4">
      <polyline points="20 12 20 22 4 22 4 12"></polyline>
      <rect x="2" y="7" width="20" height="5"></rect>
      <line x1="12" y1="22" x2="12" y2="7"></line>
      <path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"></path>
      <path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"></path>
    </svg>
    <span class="font-abeezee text-[10px] tracking-[0.2em] text-dark-blue/60 uppercase mb-4 font-bold">Sugerencia de regalo</span>
    <p class="font-abeezee text-[9px] leading-relaxed text-dark-blue/60 uppercase mb-4">
      SI DESEAN HACERNOS UN PRESENTE, PUEDEN AYUDARNOS EN NUESTRO SUEÑO DE CONSOLIDAR NUESTRO HOGAR.
    </p>
    <span class="font-abeezee text-[10px] tracking-[0.2em] text-dark-blue/80 font-bold uppercase mb-2">Lluvia de Sobres</span>
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-5 h-5 text-dark-blue/40">
      <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
      <polyline points="22,6 12,13 2,6"></polyline>
    </svg>
  </div>
</section>
