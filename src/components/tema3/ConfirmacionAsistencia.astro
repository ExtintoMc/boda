---

<section class="relative w-full py-16 px-8 flex flex-col items-center bg-white">
  <!-- Confirmación -->
  <div class="flex flex-col items-center text-center mb-16">
    <div class="w-10 h-10 rounded-full border border-dark-blue/20 flex items-center justify-center mb-4">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-5 h-5 text-dark-blue/60">
        <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
      </svg>
    </div>
    <span class="font-abeezee text-[10px] tracking-[0.2em] text-dark-blue/60 uppercase mb-4 font-bold">Confirmación</span>
    <p class="font-abeezee text-[9px] leading-relaxed text-dark-blue/60 uppercase mb-6 max-w-[200px]">
      AGRADECEMOS QUE CONFIRMES TU ASISTENCIA ANTES DEL 1 DE NOVIEMBRE DE 2026
    </p>
    <a 
      href="https://wa.me/1234567890" 
      target="_blank" 
      class="bg-dark-blue text-white font-abeezee text-[9px] tracking-[0.3em] uppercase py-3 px-10 rounded-sm hover:bg-dark-blue/90 transition-all shadow-md flex items-center gap-2"
    >
      Enviar Mensaje
      <svg viewBox="0 0 24 24" fill="currentColor" class="w-3 h-3">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"></path>
      </svg>
    </a>
  </div>

  <!-- Adults Only -->
  <div class="flex flex-col items-center text-center mb-16">
    <p class="font-abeezee text-[9px] leading-relaxed text-dark-blue/60 uppercase mb-2 max-w-[250px]">
      ADORAMOS A SUS HIJOS, PERO CREEMOS QUE NECESITAN UNA NOCHE LIBRE.
    </p>
    <p class="font-abeezee text-[10px] tracking-[0.2em] text-dark-blue/80 font-bold uppercase">SÓLO ADULTOS, POR FAVOR</p>
    
    <img 
      src="/src/assets/leaf.png" 
      class="w-40 rotate-180 opacity-30 mt-6" 
      alt="leaf"
    />
  </div>

  <p class="font-abeezee text-[10px] tracking-[0.2em] text-dark-blue/50 uppercase mb-12">ESPERAMOS CONTAR CON SU PRESENCIA</p>

  <!-- Final Photo -->
  <div class="w-full h-[300px] overflow-hidden rounded-t-lg">
    <img 
      src="/src/assets/fotos.webp" 
      class="w-full h-full object-cover" 
      alt="Juan & Lupe Final"
    />
  </div>
</section>
