<section
  class="relative h-screen w-full flex overflow-hidden bg-[radial-gradient(circle_at_center,#001d51_0%,#071739_60%,#0a1331_100%)]"
>
  <div class="absolute left-6 md:left-10 top-0 bottom-0 w-3 md:w-4 bg-pastel">
  </div>

  <img
    src="/assets/tema2/accent_dorado.png"
    class="absolute -left-37.5 md:-left-37.5 top-[30%] w-82 md:w-100 z-10 drop-shadow-md rotate-90"
    alt="Flores"
  />

  <div class="flex flex-col w-full z-20 justify-center pl-24 pr-8 py-16">
    <div
      class="flex flex-col relative items-center justify-center text-center font-parisienne text-pastel mb-30"
    >
      <img
        src="/assets/tema2/floral_dorado.png"
        alt=""
        class="w-100 h-100 absolute -z-10"
      />
      <span class="text-5xl md:text-7xl">Juan</span>
      <span class="text-3xl md:text-5xl my-2">&</span>
      <span class="text-5xl md:text-7xl">Lupe</span>
    </div>

    <h2
      class="text-center font-abeezee text-xs md:text-sm tracking-widest text-pastel mb-12"
    >
      Te invitamos a celebrar<br />nuestra boda
    </h2>

    <div class="flex items-center justify-center mb-10 w-full max-w-sm mx-auto">
      <div
        class="flex flex-col items-center justify-center text-pastel pr-4 border-r border-pastel"
      >
        <span class="text-xs md:text-sm font-bold tracking-widest uppercase"
          >Dic</span
        >
        <span
          class="text-5xl md:text-6xl font-yrsa font-bold text-pastel leading-none my-1"
          >06</span
        >
        <span class="text-xs md:text-sm font-bold">2026</span>
      </div>

      <div
        class="flex flex-col justify-center pl-4 text-pastel text-xs sm:text-sm font-yrsa"
      >
        <p class="font-bold text-sm sm:text-base mb-1">6:00 PM</p>
        <p class="font-bold mb-1">Iglesia San Pedro</p>
        <p class="pr-2">
          P.º de las Américas 2538,<br />
          Contry La Silla 1er Sector,<br />
          64850 Monterrey, N.L.
        </p>
      </div>
    </div>

    <div class="flex flex-col items-center justify-center mt-4 w-full">
      <button
        id="portada-map-btn"
        class="flex items-center gap-2 bg-pastel text-white font-abeezee text-[10px] sm:text-xs font-bold tracking-widest uppercase py-3 px-8 rounded-full shadow-lg hover:scale-105 transition-transform"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="w-4 h-4"
          fill="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"
          ></path>
        </svg>
        <span id="portada-btn-text">Ubicación</span>
      </button>

      <div
        id="portada-map-container"
        class="overflow-hidden max-h-0 opacity-0 transition-all duration-500 ease-in-out w-full max-w-sm mx-auto mt-6"
      >
        <div
          class="aspect-video w-full rounded-xl overflow-hidden shadow-lg border-2 border-pastel/10"
        >
          <iframe
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3596.868774020968!2d-100.2858172!3d25.6425482!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x8662bf784b80b721%3A0xc3f8e6e5a6b0c6c0!2sParroquia%20San%20Pedro%20Ap%C3%B3stol!5e0!3m2!1ses-419!2smx!4v1715624000000!5m2!1ses-419!2smx"
            width="100%"
            height="100%"
            style="border:0;"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"></iframe>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const btn = document.getElementById("portada-map-btn");
  const container = document.getElementById("portada-map-container");
  const btnText = document.getElementById("portada-btn-text");

  if (btn && container && btnText) {
    btn.addEventListener("click", () => {
      const isOpen = !container.classList.contains("max-h-0");

      if (isOpen) {
        container.classList.add("max-h-0", "opacity-0");
        container.classList.remove("max-h-[500px]", "opacity-100");
        btnText.textContent = "Ubicación";
      } else {
        container.classList.remove("max-h-0", "opacity-0");
        container.classList.add("max-h-[500px]", "opacity-100");
        btnText.textContent = "Cerrar Mapa";
      }
    });
  }
</script>
