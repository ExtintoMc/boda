    mapUrl: "https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3596.868774020968!2d-100.2858172!3d25.6425482!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x8662bf784b80b721%3A0xc3f8e6e5a6b0c6c0!2sParroquia%20San%20Pedro%20Ap%C3%B3stol!5e0!3m2!1ses-419!2smx!4v1715624000000!5m2!1ses-419!2smx",
  },
  {
    name: "Recepción",
    lugar: "Salón de eventos",
    Ubicacion: "Ver mapa",
    icon: "src/assets/brindis.png",
    mapUrl: "https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d115033.45427181057!2d-100.3891461!3d25.6489114!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x86629584052156eb%3A0x4bf3ef3e3d240212!2sMonterrey%2C%20N.L.!5e0!3m2!1ses-419!2smx!4v1715624000000!5m2!1ses-419!2smx",
  },
