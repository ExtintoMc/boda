---

<section class="reveal flex flex-col w-full relative overflow-hidden">
  <img
    src="/src/assets/leaf.png"
    class="absolute top-0 left-[-5%] md:w-60 w-40"
  />

  <div class="flex flex-col w-full gap-12 relative mt-40 my-10">
    {
      eventos.map((evento, index) => (
        <div class="relative flex flex-col items-center text-center">
          <img src={evento.icon} class="h-10 mb-4 z-10" />

          <h3 class="text-2xl sm:text-3xl text-dark-blue font-yrsa mb-2">
            {evento.name}
          </h3>
          <p class="text-sm sm:text-base font-abeezee text-gray-600 mb-4 tracking-wide">
            {evento.lugar}
          </p>

          <button 
            class="map-toggle-btn bg-dark-blue text-white font-abeezee text-xs tracking-widest uppercase py-2 px-6 rounded-full hover:scale-105 transition-transform shadow-md"
            data-index={index}
          >
            {evento.Ubicacion}
          </button>

          <div 
            id={`map-container-${index}`}
            class="map-container overflow-hidden max-h-0 opacity-0 transition-all duration-500 ease-in-out w-full max-w-md mx-auto mt-6 px-4"
          >
            <div class="aspect-video w-full rounded-xl overflow-hidden shadow-lg border-2 border-dark-blue/10">
              <iframe
                src={evento.mapUrl}
                width="100%"
                height="100%"
                style="border:0;"
                allowfullscreen=""
                loading="lazy"
                referrerpolicy="no-referrer-when-downgrade"
              ></iframe>
            </div>
          </div>
        </div>
      ))
    }
  </div>

  <h2
    class="text-3xl font-yrsa font-bold text-dark-blue w-3/4 mx-auto text-center my-10"
  >
    Itinerario de actividades
  </h2>

  <div class="relative w-full max-w-lg mx-auto pb-10 mb-50">
    <div
      class="absolute left-1/2 top-4 bottom-4 w-px bg-dark-blue opacity-50 -translate-x-1/2"
    >
    </div>

    {
      actividades.map((act, i) => {
        const isRight = i % 2 === 0;
        return (
          <div class="w-full flex justify-between items-center relative mb-4">
            <div
              class={`absolute top-1/2 -translate-y-1/2 w-4 sm:w-6 h-px bg-dark-blue opacity-50 ${isRight ? "left-1/2" : "right-1/2"}`}
            />

            <div class="w-1/2 pr-4 sm:pr-8 flex justify-end">
              {!isRight && (
                <div class="flex items-center gap-2 sm:gap-2 text-right">
                  <div class="flex flex-col -mt-1">
                    <span class="font-abeezee text-[10px] sm:text-xs font-bold text-dark-blue tracking-widest whitespace-nowrap">
                      {act.time}
                    </span>
                    <span class="font-yrsa text-sm sm:text-lg text-black">
                      {act.name}
                    </span>
                  </div>
                  <div class="text-dark-blue" set:html={act.icon} />
                </div>
              )}
            </div>

            <div class="w-1/2 pl-4 sm:pl-8 flex justify-start">
              {isRight && (
                <div class="flex items-center gap-3 sm:gap-4 text-left">
                  <div class="text-dark-blue" set:html={act.icon} />
                  <div class="flex flex-col -mt-1">
                    <span class="font-abeezee text-[10px] sm:text-xs font-bold text-dark-blue tracking-widest whitespace-nowrap">
                      {act.time}
                    </span>
                    <span class="font-yrsa text-sm sm:text-lg text-black">
                      {act.name}
                    </span>
                  </div>
                </div>
              )}
            </div>
          </div>
        );
      })
    }
  </div>
  <img
    src="/src/assets/leaf.png"
    class="absolute bottom-0 right-[-5%] md:w-60 w-40 rotate-180"
  />
</section>

<script>
  const buttons = document.querySelectorAll('.map-toggle-btn');
  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      const index = btn.getAttribute('data-index');
      const container = document.getElementById(`map-container-${index}`);
      if (container) {
        const isOpen = !container.classList.contains('max-h-0');
        
        if (isOpen) {
          container.classList.add('max-h-0', 'opacity-0');
          container.classList.remove('max-h-[500px]', 'opacity-100');
          btn.textContent = 'Ver mapa';
        } else {
          container.classList.remove('max-h-0', 'opacity-0');
          container.classList.add('max-h-[500px]', 'opacity-100');
          btn.textContent = 'Cerrar mapa';
        }
      }
    });
  });
</script>
