<section
  class="flex flex-col items-center justify-center w-3/4 mx-auto my-10 space-y-6"
>
  <p class="text-center font-abeezee text-sm">
    Dale play a nuestra canción
  </p>

  <audio id="audio-invitacion" src="src/assets/cancion.mp3"></audio>

  <div class="w-full max-w-xs bg-dark-blue bg-opacity-30 h-[2px] relative flex items-center">
    <div
      id="progress-dot"
      class="absolute left-0 w-3 h-3 bg-dark-blue rounded-full transition-all duration-300"
    >
    </div>
  </div>

  <div class="flex items-center justify-between w-full max-w-xs px-2 text-dark-blue">
    <button class="opacity-40 cursor-not-allowed transition" aria-label="Bajar volumen">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"></polygon>
        <line x1="15.54" y1="8.46" x2="15.54" y2="15.54"></line>
      </svg>
    </button>

    <button class="opacity-40 cursor-not-allowed transition" aria-label="Canción anterior">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
        <path d="M6 6h2v12H6zm3.5 6l8.5 6V6z"/>
      </svg>
    </button>

    <button
      id="play-button"
      class="bg-dark-blue text-white p-4 rounded-full shadow-lg hover:scale-105 transition-transform"
      aria-label="Reproducir/Pausar"
    >
      <svg
        id="play-icon"
        xmlns="http://www.w3.org/2000/svg"
        width="28"
        height="28"
        viewBox="0 0 24 24"
        fill="currentColor"
      >
        <polygon points="5 3 19 12 5 21 5 3"></polygon>
      </svg>
    </button>

    <button class="opacity-40 cursor-not-allowed transition" aria-label="Siguiente canción">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
        <path d="M6 18l8.5-6L6 6v12zM16 6v12h2V6h-2z"/>
      </svg>
    </button>

    <button class="opacity-40 cursor-not-allowed transition" aria-label="Subir volumen">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"></polygon>
        <path d="M19.07 4.93a10 10 0 0 1 0 14.14M15.54 8.46a5 5 0 0 1 0 7.07"></path>
      </svg>
    </button>
  </div>
</section>

<script>
  const audio = document.getElementById("audio-invitacion");
  const playBtn = document.getElementById("play-button");
  const playIcon = document.getElementById("play-icon");
  const progressDot = document.getElementById("progress-dot");

  const playSVG = '<polygon points="5 3 19 12 5 21 5 3"></polygon>';
  const pauseSVG =
    '<rect x="6" y="4" width="4" height="16"></rect><rect x="14" y="4" width="4" height="16"></rect>';

  if (playBtn && audio && playIcon) {
    playBtn.addEventListener("click", () => {
      if ((audio as HTMLAudioElement).paused) {
        (audio as HTMLAudioElement).play();
        playIcon.innerHTML = pauseSVG;
      } else {
        (audio as HTMLAudioElement).pause();
        playIcon.innerHTML = playSVG;
      }
    });

    audio.addEventListener("timeupdate", () => {
      const percentage = ((audio as HTMLAudioElement).currentTime / (audio as HTMLAudioElement).duration) * 100;
      if (progressDot) {
        progressDot.style.left = `${percentage}%`;
      }
    });

    audio.addEventListener("ended", () => {
      playIcon.innerHTML = playSVG;
      if (progressDot) {
        progressDot.style.left = "0%";
      }
    });
  }
</script>
